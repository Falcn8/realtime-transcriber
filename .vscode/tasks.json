{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Install analytics and build",
			"type": "shell",
			"command": "npm",
			"args": [
				"install",
				"@vercel/analytics",
				"&&",
				"npm",
				"install",
				"-D",
				"esbuild",
				"&&",
				"npm",
				"run",
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Vercel build",
			"type": "shell",
			"command": "vercel",
			"args": [
				"build"
			],
			"isBackground": false
		},
		{
			"label": "Vercel pull and build",
			"type": "shell",
			"command": "vercel",
			"args": [
				"pull",
				"--yes",
				"--environment=production",
				"&&",
				"vercel",
				"build"
			],
			"isBackground": false
		}
	]
}